# ==============================================================================
# SLN AI System - Environment Variables Example Template
# ==============================================================================
# Copy this file to '.env' on both of your devices and customize accordingly.
# This '.env' file is ignored by Git, ensuring keys are never leaked to GitHub.
# ==============================================================================

# ----- SYSTEM GENERAL CONFIG -----
ENV=development
PORT=8000
DEBUG=true

# ----- DATABASE CONFIGURATION -----
# Local postgres running inside Docker
DATABASE_URL=postgresql://sln:sln_password@postgres:5432/sln_db
POSTGRES_USER=sln
POSTGRES_PASSWORD=sln_password
POSTGRES_DB=sln_db

# ----- CACHE CONFIGURATION -----
# Redis host configured within docker-compose network
REDIS_URL=redis://redis:6379/0

# ----- VECTOR MEMORY -----
# ChromaDB endpoint configured within docker-compose network
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ----- LLM / AI ENGINE CONFIGURATION -----
# Configure your model provider API keys (Do NOT commit to git!)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ----- GITHUB MCP CONFIGURATION -----
# Used for testing automation or script actions calling GitHub APIs
GITHUB_TOKEN=your_github_personal_access_token_here
