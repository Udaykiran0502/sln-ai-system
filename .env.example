# ─────────────────────────────────────────────────────────────
# SLN AI Creative Operating System — Environment Configurations
# ─────────────────────────────────────────────────────────────

# ── AI Providers & Orchestration ──
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
DEFAULT_LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# ── Database & State Sync ──
# Local SQLite fallback default
DATABASE_URL=sqlite:///data/db/sln.db
# Production PostgreSQL connection (uncomment for multi-device setup)
# DATABASE_URL=postgresql://sln_admin:sln_password@postgres:5432/sln_db

# ── Redis Broker & Cache Sync ──
REDIS_URL=redis://redis:6379/0

# ── Chroma Vector DB (Design Memory RAG) ──
CHROMA_DB_DIR=data/chromadb
CHROMA_SERVER_HOST=chromadb
CHROMA_SERVER_PORT=8000

# ── System Runtime Parameters ──
APP_ENV=dev
APP_DEBUG=true
MAX_MEMORY_MB=12000
API_HOST=127.0.0.1
API_PORT=8000

# ── Directory Mappings (Mount Points) ──
TEMPLATE_DIR=backend/templates
FONT_DIR=assets/fonts
LOGO_DIR=assets/logos
OUTPUT_DIR=outputs
PREVIEW_DIR=outputs/previews
FINAL_DIR=outputs/final
ORDERS_DIR=data/orders
LOGS_DIR=data/logs
