# ===========================
# SLN AI System - .gitignore
# ===========================

# ----- Dependencies -----
node_modules/
.pnp/
.pnp.js
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
venv/
.venv/
env/
.env.local
.env.development.local
.env.test.local
.env.production.local
.env

# ----- Build Outputs -----
/out/
/.next/
/build/
/dist/
*.js.map

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----- OS Files -----
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ----- Docker -----
docker-compose.override.yml
.docker/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Testing -----
coverage/
.nyc_output/
*.lcov
.pytest_cache/
htmlcov/

# ----- Secrets & Credentials -----
*.pem
*.key
*.cert
*.p12
secrets/
credentials/
.secrets
*.secret

# ----- Database -----
*.sqlite3
*.db

# ----- Terraform -----
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# ----- Misc -----
.cache/
tmp/
temp/
*.bak
*.tmp
